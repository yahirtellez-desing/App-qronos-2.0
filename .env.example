# ============================================================
# QRONOS 2.0 · Variables de Entorno
# Copia este archivo como .env.local para desarrollo local
# En Vercel: agrega estas variables en Project Settings > Environment Variables
# ============================================================

# --- SUPABASE ---
# Obtén estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- GEMINI AI ---
# Obtén tu API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# --- CORS (opcional, por defecto permite todos) ---
# Pon tu dominio de Vercel para producción, ej: https://qronos.vercel.app
FRONTEND_URL=https://tu-proyecto.vercel.app

# ============================================================
# INSTRUCCIONES DE SUPABASE:
# Ejecuta este SQL en Supabase → SQL Editor:
#
# CREATE TABLE records (
#   id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   fecha DATE NOT NULL,
#   planta TEXT NOT NULL,
#   eficiencia DECIMAL(5,2) NOT NULL DEFAULT 0,
#   meta DECIMAL(5,2) NOT NULL,
#   afectaciones TEXT DEFAULT '',
#   updated_at TIMESTAMPTZ DEFAULT now(),
#   UNIQUE(fecha, planta)
# );
#
# ALTER TABLE records ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "service_role_all" ON records FOR ALL USING (true);
# ============================================================
